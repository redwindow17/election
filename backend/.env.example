PORT=4000
NODE_ENV=development

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_APPCHECK_REQUIRED=false
DEMO_AUTH_ENABLED=true

# Cloud Storage exports
GCS_EXPORT_BUCKET=your-private-export-bucket
GCS_SIGNED_URL_TTL_MINUTES=15

# BigQuery analytics
BIGQUERY_DATASET=election_analytics
BIGQUERY_EVENTS_TABLE=election_events
BIGQUERY_ROLLUPS_TABLE=daily_rollups
ANALYTICS_SALT=with-a-long-random-secret

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50
